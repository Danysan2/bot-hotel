# ========================================
# VIAJES COLOMBIA TOURS - CONFIGURACIÓN
# ========================================

# Google Sheets
GOOGLE_SHEET_ID=tu_sheet_id_aqui
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# Google Calendar (Opcional - no usado en agencia de viajes)
GOOGLE_CALENDAR_ID=tu_email@gmail.com

# Evolution API - WhatsApp
# ⚠️ IMPORTANTE: Reemplaza estos valores con tus credenciales reales de Evolution API
# Obtén estos valores de tu panel de Evolution API
EVOLUTION_API_URL=https://tu-instancia.evolution-api.com
EVOLUTION_API_KEY=tu_api_key_aqui
EVOLUTION_INSTANCE_NAME=nombre_de_tu_instancia

# Notificaciones al Profesional
# Número que recibirá notificaciones cuando clientes soliciten atención
# ⚠️ FORMATO IMPORTANTE: SIN el símbolo + al inicio
# Formato correcto: 57 (código país) + número sin espacios
# Ejemplo: 573042217935
PROFESSIONAL_PHONE=573209855847

# Servidor
PORT=8000
HOST=0.0.0.0
DEBUG=True

# Timezone
TIMEZONE=America/Bogota

# ========================================
# INSTRUCCIONES:
# ========================================
# 1. Copiar este archivo como .env
# 2. Reemplazar los valores de ejemplo con tus datos reales
# 3. NO compartir el archivo .env (contiene credenciales)
# 4. El archivo .env está en .gitignore por seguridad
